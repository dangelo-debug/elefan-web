---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import '../styles/global.css';
---

<Layout>
  <Navbar />
  <Hero />

  <!-- SERVICIOS VIDEO -->
  <section class="servicios-video">
    <video autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover">
      <source src="/images/video-elefan-1.mp4" type="video/mp4" />
    </video>
    <div class="servicios-video__content">
      <h2 class="servicios-video__title">Servicios</h2>
      <p class="servicios-video__text">Hay una oportunidad única de cambiar la forma en que se comunican las empresas y marcas. Con un enfoque en formatos y productos innovadores, creamos mensajes que no solo se escuchan, sino que conectan de verdad y generan un impacto real.</p>
      <a href="/servicios" class="btn-dark">CONOCE MÁS</a>
    </div>
  </section>

  <!-- PORTAFOLIO -->
  <div id="portafolio">
    <ProjectGrid />
  </div>

  <!-- SOMOS -->
  <section id="somos-section" class="somos-section">
    <img id="somos-img" src="/images/somos.jpg" alt="Somos Elefan" class="somos-section__bg" />
    <div id="somos-text" class="somos-section__content">
      <h2 class="somos-section__title">Somos</h2>
      <p class="somos-section__body">
        Personas con iniciativa que le encantan las ideas que agreguen valor y generen proyectos que movilicen a las audiencias. Creemos que acciones vinculadas a la creatividad y a la comunicación lúdica conceptual permite conectarnos de forma más profunda con las personas, generando vínculo, entendimiento, aprendizaje efectivo y sobretodo, buenos recuerdos.
      </p>
      <a href="/somos" class="btn-outline-dark">Conoce más</a>
    </div>
  </section>

  <!-- PROYECTO DEL MES -->
  <section class="proyecto-mes">
    <img src="/images/3.-proyecto-del-mes-1024x1024.jpg" alt="" class="proyecto-mes__bg" />
    <div class="proyecto-mes__content">
      <h2 class="proyecto-mes__title">Proyecto <strong>del mes</strong></h2>
      <div class="video-ratio">
        <iframe
          src="https://www.youtube.com/embed/sEC3W2QH4tc"
          title="Proyecto del mes"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="blog-section">
    <h2 class="blog-section__title">Blog</h2>
    <p class="blog-section__subtitle">Ideas, reflexiones y tendencias del mundo creativo</p>
    <div class="blog-grid">
      <a href="/blog/el-equilibrio-en-la-productividad-una-vision-mas-humana-y-sostenible" class="blog-card">
        <img src="/images/Productividad-blog.png" alt="" class="blog-card__img" />
        <h3 class="blog-card__title">El Equilibrio en la Productividad: Una visión más humana y sostenible.</h3>
        <p class="blog-card__excerpt">Desde nuestra experiencia entendemos que la productividad es esencial, pero también reconocemos su lado oscuro.</p>
      </a>
      <a href="/blog/la-escucha-adaptativa-la-clave-para-la-comunicacion-en-el-mundo-creativo" class="blog-card">
        <img src="/images/Escucha-blog.png" alt="" class="blog-card__img" />
        <h3 class="blog-card__title">La Escucha Adaptativa: La clave para la comunicación en el mundo creativo</h3>
        <p class="blog-card__excerpt">En Agencia Elefan, reconocemos que la escucha es una habilidad crítica, especialmente en el ámbito creativo.</p>
      </a>
      <a href="/blog/microlearning-la-respuesta-creativa-para-el-aprendizaje-agil" class="blog-card">
        <img src="/images/Micro-elearning-blog.png" alt="" class="blog-card__img" />
        <h3 class="blog-card__title">Microlearning: La respuesta creativa para el aprendizaje ágil</h3>
        <p class="blog-card__excerpt">¡El aprendizaje está cambiando! Hoy todo es más rápido e instantáneo. El microlearning es la respuesta.</p>
      </a>
    </div>
    <div style="text-align:center; margin-top:48px">
      <a href="/blog" class="btn-outline-dark">Ver todos</a>
    </div>
  </section>

  <!-- CLIENTES -->
  <section class="clientes-section">
    <h2 class="clientes-section__title">Nuestros Clientes</h2>
    <p class="clientes-section__subtitle">Han confiado en nosotros</p>
    <div class="clientes-grid">
      <img src="/images/logo-enaex.png" alt="Enaex" class="cliente-logo" />
      <img src="/images/cencosud.png" alt="Cencosud" class="cliente-logo" />
      <img src="/images/logo-softserve_V03.png" alt="SoftServe" class="cliente-logo" />
      <img src="/images/LOGO-HUMIND.png" alt="Humind" class="cliente-logo" />
      <img src="/images/LogoCOPEC-9_v03.png" alt="Copec" class="cliente-logo" />
      <img src="/images/levis.png" alt="Levis" class="cliente-logo" />
      <img src="/images/BAnco-Falabella-Logo.png" alt="Banco Falabella" class="cliente-logo" />
      <img src="/images/cencosudscotiabank-1.png" alt="Cencosud Scotiabank" class="cliente-logo" />
      <img src="/images/jumbo.png" alt="Jumbo" class="cliente-logo" />
      <img src="/images/Inacap-Logo_v03.png" alt="INACAP" class="cliente-logo" />
      <img src="/images/latam-2.png" alt="LATAM" class="cliente-logo" />
      <img src="/images/Logo_ACHS.png" alt="ACHS" class="cliente-logo" />
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto" class="contacto-section">
    <div class="contacto-grid">
      <div class="contacto-form">
        <h2 class="contacto-title">Contacto</h2>
        <p class="contacto-intro">Si tienes una inquietud, una problemática o una idea que echar adelante, comunícate con nosotros.</p>
        <form name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="form">
          <input type="hidden" name="form-name" value="contacto" />
          <p style="display:none"><label>No llenar: <input name="bot-field" /></label></p>
          <div class="form__field">
            <label class="form__label">Nombre</label>
            <input name="nombre" type="text" required class="form__input" />
          </div>
          <div class="form__field">
            <label class="form__label">Email</label>
            <input name="email" type="email" required class="form__input" />
          </div>
          <div class="form__field">
            <label class="form__label">Tipo de proyecto</label>
            <select name="tipo" class="form__select">
              <option value="">Selecciona una opción</option>
              <option value="comunicacion-interna">Comunicación Interna</option>
              <option value="capacitacion">Capacitación</option>
              <option value="produccion-audiovisual">Producción Audiovisual</option>
              <option value="comunicacion-masiva">Comunicación Masiva</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div class="form__field">
            <label class="form__label">Mensaje</label>
            <textarea name="mensaje" rows="4" required class="form__textarea"></textarea>
          </div>
          <button type="submit" class="btn-submit">Enviar mensaje</button>
        </form>
      </div>
      <div class="contacto-info">
        <div class="contacto-info__block">
          <h3 class="contacto-info__heading">¿Ayuda?</h3>
          <p class="contacto-info__text">Correo: <a href="mailto:hola@elefan.cl" class="contacto-link">hola@elefan.cl</a></p>
          <p class="contacto-info__text">Teléfono: <a href="tel:+56996265972" class="contacto-link">+569 96265972</a> / <a href="tel:+56990990251" class="contacto-link">+569 90990251</a></p>
        </div>
        <div class="contacto-info__block">
          <h3 class="contacto-info__heading">Síguenos</h3>
          <div style="display:flex; gap:16px; flex-wrap:wrap">
            <a href="https://instagram.com/elefanagencia" target="_blank" class="btn-social">Instagram</a>
            <a href="https://linkedin.com/company/elefan" target="_blank" class="btn-social">LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <img src="/images/logo-elefan.png" alt="Elefan" class="footer__logo" />
    <nav class="footer__nav">
      <a href="/somos" class="footer__link">Somos</a>
      <a href="/servicios" class="footer__link">Servicios</a>
      <a href="/proyectos" class="footer__link">Proyectos</a>
      <a href="/blog" class="footer__link">Blog</a>
      <a href="#contacto" class="footer__link">Contacto</a>
    </nav>
    <p class="footer__copy">© 2025 Agencia Elefan. Todos los derechos reservados.</p>
  </footer>

  <script>
    const section = document.getElementById('somos-section');
    const text = document.getElementById('somos-text');
    const img = document.getElementById('somos-img');

    window.addEventListener('scroll', () => {
      if (!section || !text || !img) return;
      const rect = section.getBoundingClientRect();
      const windowH = window.innerHeight;
      if (rect.top < windowH && rect.bottom > 0) {
        const progress = (windowH - rect.top) / (windowH + rect.height);
        img.style.transform = `translateY(${progress * 60 - 30}px)`;
      }
      if (rect.top < windowH * 0.75) {
        text.style.opacity = '1';
        text.style.transform = 'translateY(0)';
      }
    });
  </script>

</Layout>

<style>
/* ---- SERVICIOS VIDEO ---- */
.servicios-video {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}
.servicios-video__content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 80px;
  background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 70%, transparent 100%);
}
.servicios-video__title {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 900;
  color: white;
  margin-bottom: 16px;
}
.servicios-video__text {
  font-size: 1rem;
  color: rgba(255,255,255,0.9);
  max-width: 420px;
  line-height: 1.6;
  margin-bottom: 32px;
}
.btn-dark {
  display: inline-block;
  background: white;
  color: #1a1a1a;
  padding: 12px 28px;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-decoration: none;
  width: fit-content;
}

/* ---- SOMOS ---- */
.somos-section {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 80px;
}
.somos-section__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 110%;
  object-fit: cover;
  z-index: 0;
  top: -5%;
}
.somos-section__content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 700px;
  padding: 0 40px;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}
.somos-section__title {
  font-size: 3rem;
  font-weight: 900;
  color: #1a1a1a;
  margin-bottom: 24px;
}
.somos-section__body {
  font-size: 1rem;
  color: #1a1a1a;
  line-height: 1.8;
  font-weight: 300;
}
.btn-outline-dark {
  display: inline-block;
  margin-top: 28px;
  border: 2px solid #1a1a1a;
  color: #1a1a1a;
  padding: 12px 32px;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
}

/* ---- PROYECTO DEL MES ---- */
.proyecto-mes {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 40px;
}
.proyecto-mes__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.proyecto-mes__content {
  position: relative;
  z-index: 1;
  text-align: center;
  width: 100%;
  max-width: 800px;
}
.proyecto-mes__title {
  font-size: 2.8rem;
  color: white;
  margin-bottom: 48px;
}
.video-ratio {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
}
.video-ratio iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* ---- BLOG ---- */
.blog-section {
  padding: 80px 60px;
  max-width: 1200px;
  margin: 0 auto;
}
.blog-section__title {
  font-size: 2.5rem;
  font-weight: 900;
  text-align: center;
  margin-bottom: 8px;
}
.blog-section__subtitle {
  text-align: center;
  color: #888;
  font-weight: 300;
  margin-bottom: 48px;
}
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.blog-card {
  text-decoration: none;
  color: inherit;
}
.blog-card__img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  display: block;
}
.blog-card__title {
  font-size: 0.95rem;
  font-weight: 700;
  margin: 16px 0 8px;
  color: #333;
}
.blog-card__excerpt {
  font-size: 0.85rem;
  color: #888;
  font-weight: 300;
}

/* ---- CLIENTES ---- */
.clientes-section {
  background: #3a3d47;
  padding: 80px 60px;
  text-align: center;
}
.clientes-section__title {
  color: white;
  font-weight: 900;
  font-size: 2.5rem;
  margin-bottom: 8px;
  text-transform: uppercase;
}
.clientes-section__subtitle {
  color: white;
  font-weight: 300;
  margin-bottom: 60px;
  text-transform: uppercase;
  letter-spacing: 2px;
}
.clientes-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px 60px;
  align-items: center;
  justify-items: center;
}
.cliente-logo {
  max-height: 50px;
  max-width: 140px;
  filter: grayscale(100%) brightness(0.7);
  object-fit: contain;
}

/* ---- CONTACTO ---- */
.contacto-section {
  background: #2d2d2d;
  padding: 80px 60px;
}
.contacto-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contacto-title {
  font-size: 2.8rem;
  font-weight: 900;
  color: #f5c518;
  margin-bottom: 16px;
}
.contacto-intro {
  color: #ccc;
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 48px;
}
.form {
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.form__field { display: flex; flex-direction: column; }
.form__label {
  color: #aaa;
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.form__input,
.form__textarea {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid #555;
  padding: 10px 0;
  color: white;
  font-size: 1rem;
  outline: none;
  font-family: inherit;
}
.form__select {
  width: 100%;
  background: #2d2d2d;
  border: none;
  border-bottom: 1px solid #555;
  padding: 10px 0;
  color: #aaa;
  font-size: 1rem;
  outline: none;
  font-family: inherit;
  appearance: none;
}
.form__textarea { resize: none; }
.btn-submit {
  margin-top: 8px;
  background: #f5c518;
  color: #1a1a1a;
  border: none;
  padding: 16px 40px;
  font-size: 0.85rem;
  font-weight: 900;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  width: fit-content;
  font-family: inherit;
}
.contacto-info {
  padding-top: 100px;
}
.contacto-info__block {
  margin-bottom: 48px;
}
.contacto-info__heading {
  color: white;
  font-weight: 900;
  font-size: 1.2rem;
  margin-bottom: 20px;
}
.contacto-info__text {
  color: #aaa;
  font-weight: 300;
  margin-bottom: 8px;
}
.contacto-link {
  color: #f5c518;
  text-decoration: none;
}
.btn-social {
  color: #f5c518;
  text-decoration: none;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  border: 1px solid #f5c518;
  padding: 10px 20px;
}

/* ---- FOOTER ---- */
.footer {
  background: #1a1a1a;
  padding: 40px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 24px;
}
.footer__logo {
  height: 36px;
  filter: invert(1);
}
.footer__nav {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
}
.footer__link {
  color: #555;
  text-decoration: none;
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 300;
}
.footer__copy {
  color: #444;
  font-size: 0.75rem;
  font-weight: 300;
}

/* ============================================
   RESPONSIVO — TABLET (≤1024px)
   ============================================ */
@media (max-width: 1024px) {
  .blog-grid {
    grid-template-columns: 1fr 1fr;
  }
  .clientes-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .contacto-grid {
    gap: 48px;
  }
}

/* ============================================
   RESPONSIVO — MÓVIL (≤768px)
   ============================================ */
@media (max-width: 768px) {
  /* Servicios video */
  .servicios-video__content {
    padding: 0 24px;
  }.servicios-video__content {
  padding: 0 24px;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 100%);
  justify-content: flex-end;
  padding-bottom: 48px;
}

  /* Somos */
  .somos-section {
    padding-bottom: 48px;
  }
  .somos-section__content {
    padding: 0 24px;
  }
  .somos-section__title {
    font-size: 2rem;
  }

  /* Proyecto del mes */
  .proyecto-mes {
    padding: 60px 24px;
    min-height: auto;
  }
  .proyecto-mes__title {
    font-size: 1.8rem;
    margin-bottom: 28px;
  }

  /* Blog */
  .blog-section {
    padding: 60px 24px;
  }
  .blog-section__title {
    font-size: 1.8rem;
  }
  .blog-grid {
    grid-template-columns: 1fr;
  }

  /* Clientes */
  .clientes-section {
    padding: 60px 24px;
  }
  .clientes-section__title {
    font-size: 1.6rem;
  }
  .clientes-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  /* Contacto */
  .contacto-section {
    padding: 60px 24px;
  }
  .contacto-grid {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .contacto-title {
    font-size: 2rem;
  }
  .contacto-info {
    padding-top: 0;
  }

  /* Footer */
  .footer {
    padding: 40px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }
  .footer__nav {
    gap: 16px;
  }
}
</style>