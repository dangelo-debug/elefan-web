---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

const servicios = [
  { num: "01", titulo: "Comunicaciones Internas", texto: "Creamos y desarrollamos comunicaciones internas para apoyar sus estrategias corporativas, procesos e hitos. Generamos estrategias, soluciones creativas, conceptos, ideas y métodos con los que las empresas pueden fomentar y construir una cultura sólida, cercana y que logre una mayor conexión y compromiso con sus equipos." },
  { num: "02", titulo: "Capacitación", texto: "Creamos capacitaciones innovadoras y lúdicas que transformarán la forma en que los colaboradores aprenden y se desarrollan. Nuestro enfoque creativo y dinámico genera un ambiente de aprendizaje único, donde las personas se entretienen mientras adquieren nuevos conocimientos y habilidades." },
  { num: "03", titulo: "Construcción de Cultura, Propósito e Identidad", texto: "El desarrollo organizacional requiere de comunicaciones construidas especialmente para cada empresa. Acompañamos estratégicamente la implementación de prácticas y procesos que fortalezcan la gestión del cambio, la gestión del talento y otros aspectos clave para el crecimiento de la empresa." },
  { num: "04", titulo: "Comunicación Planes de Incentivo", texto: "Creamos campañas para darle fuerza a los planes de incentivo, usando un enfoque estratégico, lúdico, cercano y con impronta, para transmitir de manera efectiva los beneficios para el colaborador. Estrategias creativas, canales y formatos innovadores y mensajes impactantes que motiven a las audiencias." },
  { num: "05", titulo: "Creación de Contenidos y Experiencia", texto: "Somos fuente y creación de contenidos únicos para las empresas. Creados y diseñados a la medida en diversos formatos: narrativas, historias, relatos, épicas, proyectos culturales, entre muchos otros dependiendo de la necesidad y contexto." },
  { num: "06", titulo: "Employee Experience", texto: "Creamos experiencias significativas que colocan a los empleados en el centro de la cultura organizacional. Diseñamos iniciativas que mejoren el bienestar, el compromiso y la satisfacción en el lugar de trabajo, ayudando a construir una cultura donde cada colaborador se sienta valorado y motivado." },
  { num: "07", titulo: "Employee Advocacy", texto: "Ayudamos a convertir a tu equipo en embajadores de la marca, promoviendo su participación activa en la promoción de la empresa y sus valores. Fortalecemos el sentido de pertenencia, empoderamos a los colaboradores para que compartan su experiencia y creamos una cultura de colaboración y participación." },
  { num: "08", titulo: "Producciones", texto: "Desde la producción, podemos hacer y pensar casi todo. Nuestra experiencia nos permite diseñar e implementar eventos, activaciones en oficinas, intervenciones lúdicas, creación de artefactos, producir eventos, realizar un cautivante video corporativo, y tantas cosas más. Somos versátiles y puedes desafiarnos con lo que sea." }
];
---

<Layout title="Servicios — Elefan">
  <Navbar />

  <!-- Hero -->
  <section class="hero-srv">
    <img src="/images/305x230mm_1_.jpg" alt="" class="hero-srv__bg" />
    <div class="hero-srv__overlay"></div>
    <div class="hero-srv__content">
      <p class="label-orange">Lo que nos apasiona hacer</p>
      <h1 class="hero-srv__title">Servicios</h1>
      <p class="hero-srv__sub">Hay una oportunidad única de cambiar la forma en que se comunican las empresas y marcas. Con formatos innovadores, creamos mensajes que no solo se escuchan, sino que conectan de verdad y generan impacto real.</p>
    </div>
  </section>

  <!-- Quiénes somos -->
  <section class="quienes-srv">
    <img src="http://www.elefan.cl/wp-content/uploads/2023/11/BG.jpg" alt="" class="quienes-srv__bg" />
    <div class="quienes-srv__overlay"></div>
    <div class="quienes-srv__left">
      <p class="label-gold">Agencia Elefan</p>
      <h2 class="quienes-srv__title">Somos una agencia boutique especializada en entregas de alto estándar</h2>
    </div>
    <div class="quienes-srv__right">
      <p class="quienes-srv__body">Somos una agencia de comunicaciones y creativa chilena fundada el 2017 en Santiago. Con el correr de los años hemos encontrado nuestro camino que se materializa en lo que entregamos: innovación, creatividad y miradas distintas a hacer las cosas.</p>
      <p class="quienes-srv__body">Somos personas con iniciativa que le encantan las ideas que agreguen valor y generen proyectos que movilicen a las audiencias. Creemos que acciones vinculadas a la creatividad y a la comunicación lúdica conceptual permite conectarnos de forma más profunda con las personas.</p>
    </div>
  </section>

  <!-- Lista servicios -->
  <section class="lista-srv">
    <p class="label-orange" style="text-align:center">Nuestros servicios</p>
    <h2 class="section-title">Lo que hacemos</h2>
    {servicios.map((s) => (
      <div class="srv-item">
        <span class="srv-num">{s.num}</span>
        <div class="srv-copy">
          <h3 class="srv-titulo">{s.titulo}</h3>
          <p class="srv-texto">{s.texto}</p>
        </div>
      </div>
    ))}
  </section>

  <!-- Propuesta de valor -->
  <section class="propuesta-srv">
    <img src="/images/305c230mm_2_1_.jpg" alt="" class="propuesta-srv__bg" />
    <div class="propuesta-srv__overlay"></div>
    <div class="propuesta-srv__inner">
      <p class="label-orange" style="text-align:center">Nuestra diferencia</p>
      <h2 class="section-title">Propuesta de valor</h2>
      <div class="cards-3">
        <div class="card-blanco">
          <svg viewBox="0 0 48 48" fill="none" stroke="#c8860a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:40px;height:40px;margin-bottom:20px">
            <circle cx="24" cy="24" r="10"/>
            <line x1="24" y1="4" x2="24" y2="10"/><line x1="24" y1="38" x2="24" y2="44"/>
            <line x1="4" y1="24" x2="10" y2="24"/><line x1="38" y1="24" x2="44" y2="24"/>
            <line x1="9" y1="9" x2="13" y2="13"/><line x1="35" y1="35" x2="39" y2="39"/>
            <line x1="39" y1="9" x2="35" y2="13"/><line x1="13" y1="35" x2="9" y2="39"/>
          </svg>
          <h3 class="card-title">Creatividad e Identidad Visual</h3>
          <p class="card-body">Cada pieza gráfica refleja nuestro compromiso con la dedicación y el cariño, asegurando que la información cautive y sorprenda a las audiencias.</p>
        </div>
        <div class="card-blanco">
          <svg viewBox="0 0 48 48" fill="none" stroke="#c8860a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:40px;height:40px;margin-bottom:20px">
            <path d="M24 8l3 9h9l-7 5 3 9-8-6-8 6 3-9-7-5h9z"/>
          </svg>
          <h3 class="card-title">Siempre Buscando una Idea</h3>
          <p class="card-body">La innovación y la creatividad son el corazón de todo lo que hacemos. A cada proyecto le damos una vuelta creativa que deja una impresión memorable.</p>
        </div>
        <div class="card-blanco">
          <svg viewBox="0 0 48 48" fill="none" stroke="#c8860a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:40px;height:40px;margin-bottom:20px">
            <rect x="4" y="12" width="28" height="20" rx="3"/>
            <path d="M32 20l12-8v24l-12-8"/>
          </svg>
          <h3 class="card-title">Especialización Audiovisual</h3>
          <p class="card-body">Desde animaciones hasta grabaciones en múltiples formatos, manejamos cada detalle desde la conceptualización hasta la postproducción.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video CTA -->
  <section class="video-cta">
    <div class="video-cta__copy">
      <p class="label-gold">En acción</p>
      <h2 class="video-cta__title">Nuestra forma de transformar la comunicación</h2>
      <p class="video-cta__body">Nuestra misión es convertir cada interacción en una oportunidad para fortalecer el sentido de pertenencia, fomentar la innovación y asegurar que cada colaborador se sienta valorado y empoderado.</p>
      <a href="/#contacto" class="btn-yellow">Conversemos</a>
    </div>
    <div class="video-ratio">
      <iframe
        src="https://www.youtube.com/embed/4WKqL4MjxCE"
        title="Agencia Elefan"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        style="position:absolute; inset:0; width:100%; height:100%"
      ></iframe>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer-page">
    <img src="/images/logo-elefan.png" alt="Elefan" class="footer-page__logo" />
    <nav class="footer-page__nav">
      <a href="/" class="footer-page__link">Home</a>
      <a href="/proyectos" class="footer-page__link">Proyectos</a>
      <a href="/blog" class="footer-page__link">Blog</a>
    </nav>
    <p class="footer-page__copy">© 2025 Agencia Elefan</p>
  </footer>

</Layout>

<style>
/* ---- HERO ---- */
.hero-srv {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.hero-srv__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  z-index: 0;
}
.hero-srv__overlay {
  position: absolute;
  inset: 0;
  background: rgba(248,245,238,0.55);
  z-index: 1;
}
.hero-srv__content {
  position: relative;
  z-index: 2;
  padding: 0 80px;
  max-width: 560px;
}
.hero-srv__title {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 900;
  color: #1a1a1a;
  line-height: 1.05;
  margin-bottom: 24px;
}
.hero-srv__sub {
  font-size: 1.05rem;
  color: #333;
  font-weight: 300;
  line-height: 1.8;
}

/* ---- QUIÉNES ---- */
.quienes-srv {
  position: relative;
  padding: 100px 80px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  overflow: hidden;
}
.quienes-srv__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.quienes-srv__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.78);
  z-index: 1;
}
.quienes-srv__left,
.quienes-srv__right {
  position: relative;
  z-index: 2;
}
.quienes-srv__title {
  font-size: 2.2rem;
  font-weight: 900;
  color: white;
  line-height: 1.2;
}
.quienes-srv__body {
  font-size: 1rem;
  color: #ccc;
  font-weight: 300;
  line-height: 1.9;
  margin-bottom: 24px;
}

/* ---- LISTA SERVICIOS ---- */
.lista-srv {
  padding: 100px 80px;
  max-width: 1100px;
  margin: 0 auto;
}
.srv-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 40px;
  align-items: start;
  padding: 48px 0;
  border-top: 1px solid #e8e8e8;
}
.srv-item:last-child {
  border-bottom: 1px solid #e8e8e8;
}
.srv-num {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: #c8860a;
  padding-top: 6px;
}
.srv-titulo {
  font-size: 1.4rem;
  font-weight: 900;
  color: #1a1a1a;
  margin-bottom: 14px;
}
.srv-texto {
  font-size: 1rem;
  color: #555;
  font-weight: 300;
  line-height: 1.85;
}

/* ---- PROPUESTA ---- */
.propuesta-srv {
  position: relative;
  padding: 100px 80px;
  overflow: hidden;
}
.propuesta-srv__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  z-index: 0;
}
.propuesta-srv__overlay {
  position: absolute;
  inset: 0;
  background: rgba(248,245,238,0.88);
  z-index: 1;
}
.propuesta-srv__inner {
  position: relative;
  z-index: 2;
  max-width: 1100px;
  margin: 0 auto;
}

/* ---- VIDEO CTA ---- */
.video-cta {
  background: #1a1a1a;
  padding: 100px 80px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.video-cta__title {
  font-size: 2.2rem;
  font-weight: 900;
  color: white;
  line-height: 1.2;
  margin-bottom: 24px;
}
.video-cta__body {
  font-size: 1rem;
  color: #aaa;
  font-weight: 300;
  line-height: 1.8;
  margin-bottom: 40px;
}
.video-ratio {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
}

/* ---- SHARED ---- */
.label-gold {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #f5c518;
  margin-bottom: 24px;
  display: block;
}
.label-orange {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #c8860a;
  margin-bottom: 16px;
  display: block;
}
.section-title {
  font-size: 2.5rem;
  font-weight: 900;
  text-align: center;
  margin-bottom: 64px;
  color: #1a1a1a;
}
.btn-yellow {
  display: inline-block;
  background: #f5c518;
  color: #1a1a1a;
  padding: 16px 40px;
  font-size: 0.85rem;
  font-weight: 900;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  width: fit-content;
}
.cards-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.card-blanco {
  padding: 40px;
  background: white;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.card-title {
  font-size: 1rem;
  font-weight: 900;
  color: #1a1a1a;
  margin-bottom: 14px;
}
.card-body {
  font-size: 0.9rem;
  color: #666;
  font-weight: 300;
  line-height: 1.8;
}
.footer-page {
  background: #111;
  padding: 40px 80px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 24px;
}
.footer-page__logo { height: 36px; filter: invert(1); }
.footer-page__nav { display: flex; gap: 32px; flex-wrap: wrap; }
.footer-page__link { color: #555; text-decoration: none; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; font-weight: 300; }
.footer-page__copy { color: #444; font-size: 0.75rem; font-weight: 300; }

/* ============================================
   TABLET (≤1024px)
   ============================================ */
@media (max-width: 1024px) {
  .cards-3 { grid-template-columns: 1fr 1fr; }
  .quienes-srv { gap: 48px; }
  .video-cta { gap: 48px; }
}

/* ============================================
   MÓVIL (≤768px)
   ============================================ */
@media (max-width: 768px) {
  /* Hero */
  .hero-srv__content { padding: 0 24px; }

  /* Quiénes */
  .quienes-srv {
    grid-template-columns: 1fr;
    padding: 60px 24px;
    gap: 32px;
  }
  .quienes-srv__title { font-size: 1.7rem; }

  /* Lista servicios */
  .lista-srv { padding: 60px 24px; }
  .section-title { font-size: 1.8rem; margin-bottom: 40px; }
  .srv-item {
    grid-template-columns: 40px 1fr;
    gap: 20px;
    padding: 32px 0;
  }
  .srv-titulo { font-size: 1.1rem; }

  /* Propuesta */
  .propuesta-srv { padding: 60px 24px; }
  .cards-3 { grid-template-columns: 1fr; }
  .card-blanco { padding: 28px; }

  /* Video CTA */
  .video-cta {
    grid-template-columns: 1fr;
    padding: 60px 24px;
    gap: 40px;
  }
  .video-cta__title { font-size: 1.7rem; }

  /* Footer */
  .footer-page {
    padding: 40px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }
  .footer-page__nav { gap: 16px; }
}
</style>