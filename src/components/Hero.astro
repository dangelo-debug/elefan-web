---
const slides = [
  {
    image: "http://www.elefan.cl/wp-content/uploads/2024/02/slide_elefan_comunicaciones-internas.jpg",
    align: "left",
    lines: [
      { text: "Ideas audaces", color: "#ffffff", size: "3.5rem", mobilSize: "2rem" },
      { text: "Para empresas", color: "#f5c518", size: "4rem", mobilSize: "2.4rem" },
      { text: "que inspiran", color: "#f5c518", size: "4rem", mobilSize: "2.4rem" }
    ]
  },
  {
    image: "http://www.elefan.cl/wp-content/uploads/2024/02/slide2_elefan_ideas-que-cambian.jpg",
    align: "left",
    lines: [
      { text: "Elevamos marcas,", color: "#1a1a1a", size: "2.2rem", mobilSize: "1.4rem" },
      { text: "transformamos negocios", color: "#1a1a1a", size: "2.2rem", mobilSize: "1.4rem" },
      { text: "y conectamos con el futuro.", color: "#ffffff", size: "2.2rem", mobilSize: "1.4rem" }
    ]
  },
  {
    image: "http://www.elefan.cl/wp-content/uploads/2023/12/slider-3.jpg",
    align: "left",
    lines: [
      { text: "Donde hay una idea", color: "#1a1a1a", size: "3.5rem", mobilSize: "2rem" },
      { text: "hay un camino", color: "#c8860a", size: "4rem", mobilSize: "2.4rem" }
    ]
  },
  {
    image: "http://www.elefan.cl/wp-content/uploads/2025/08/Slider-Hotel-SET.jpg",
    align: "center",
    lines: [
      { text: "Historias que conectan", color: "#ffffff", size: "3.5rem", mobilSize: "2rem" },
      { text: "Aprendizaje diferente.", color: "#f5c518", size: "4rem", mobilSize: "2.4rem" }
    ]
  }
];
---

<section style="position:relative; width:100%; height:100vh; overflow:hidden">
  <div id="slider" style="display:flex; height:100%; width:400%; transition:transform 0.7s ease">
    {slides.map((slide) => (
      <div class="slide-item" style="position:relative; height:100%; width:25%; flex-shrink:0">
        <img src={slide.image} alt="" style="width:100%; height:100%; object-fit:cover" />
        <div
          class="slide-text"
          style={"position:absolute; inset:0; display:flex; flex-direction:column; justify-content:center; padding:0 80px; text-align:" + slide.align}
        >
          {slide.lines.map((line, i) => (
            <p
              class={"sl nth" + (i+1) + " slide-line"}
              style={
                "--fs-desktop:" + line.size + ";" +
                "--fs-mobile:" + line.mobilSize + ";" +
                "color:" + line.color + ";" +
                "font-weight:900;" +
                "font-size:var(--fs-desktop);" +
                "line-height:1.15;" +
                "margin-bottom:6px"
              }
            >{line.text}</p>
          ))}
        </div>
      </div>
    ))}
  </div>
  <button id="prev" class="slider-btn slider-btn--prev">&#8249;</button>
  <button id="next" class="slider-btn slider-btn--next">&#8250;</button>
</section>

<style>
  .sl { opacity:0; transform:translateY(20px); transition:opacity 0.6s ease, transform 0.6s ease; }
  .nth1 { transition-delay:0.1s }
  .nth2 { transition-delay:0.3s }
  .nth3 { transition-delay:0.5s }
  .slide-active .sl { opacity:1; transform:translateY(0) }

  /* Sombra de texto en todos los slides */
  .slide-line {
    text-shadow: 0 2px 12px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.4);
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: white;
    font-size: 3rem;
    opacity: 0.7;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 16px;
    line-height: 1;
    transition: opacity 0.2s;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }
  .slider-btn:hover { opacity: 1; }
  .slider-btn--prev { left: 16px; }
  .slider-btn--next { right: 16px; }

  @media (max-width: 768px) {
    .slide-text {
      padding: 0 24px !important;
      /* Fondo semitransparente detrás del texto en móvil */
      background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 100%);
      justify-content: flex-end !important;
      padding-bottom: 60px !important;
    }
    .slide-line {
      font-size: var(--fs-mobile) !important;
      text-shadow: 0 2px 16px rgba(0,0,0,0.8), 0 1px 4px rgba(0,0,0,0.6);
    }
    .slider-btn {
      font-size: 2rem;
      padding: 4px 10px;
    }
  }
</style>

<script>
  let current = 0;
  const total = 4;
  const slider = document.getElementById('slider') as HTMLElement;
  const slides = document.querySelectorAll('.slide-item');
  function goTo(n: number) {
    slides[current].classList.remove('slide-active');
    current = ((n % total) + total) % total;
    slider.style.transform = "translateX(-" + (current * 25) + "%)";
    setTimeout(() => slides[current].classList.add('slide-active'), 50);
  }
  slides[0].classList.add('slide-active');
  document.getElementById('prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('next')?.addEventListener('click', () => goTo(current + 1));
  setInterval(() => goTo(current + 1), 6000);
</script>